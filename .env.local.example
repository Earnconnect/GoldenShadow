# ─────────────────────────────────────────────────────────────
# Golden Shadow Publishing — environment variables
# Copy this file to `.env.local` and fill in your values.
# ─────────────────────────────────────────────────────────────

# ── Supabase (Phase 3: applications + admin) ────────────────
# Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key — SERVER ONLY, never exposed to the browser.
# Used by the Stripe webhook to record orders. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=

# ── Stripe (Phase 4: payments) ──────────────────────────────
# Stripe Dashboard → Developers → API keys (use test keys first)
STRIPE_SECRET_KEY=

# Webhook signing secret — Stripe Dashboard → Developers → Webhooks,
# or from `stripe listen` when testing locally.
STRIPE_WEBHOOK_SECRET=

# Public base URL used for Stripe success/cancel redirects.
# Local dev: http://localhost:3000   Production: https://yourdomain.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Anthropic / Claude (Phase 6: Studio Engine) ─────────────
# Server-only — NEVER prefix with NEXT_PUBLIC. From console.anthropic.com → API keys.
ANTHROPIC_API_KEY=
# Optional model overrides (sensible defaults are baked in):
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MODEL_HEAVY=claude-opus-4-8
